{
  "name": "comasintproject1",
  "version": "0.0.1",
  "description": "Build and deployment scripts",
  "workspaces": [
    "project1",
    "project2"
  ],
  "scripts": {
    "clean": "rimraf --glob resources mta_archives mta-op*",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "undeploy": "cf undeploy comasintproject1 --delete-services --delete-service-keys --delete-service-brokers"
  },
  "devDependencies": {
    "@sap-ux/eslint-plugin-fiori-tools": "^9.0.0",
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^4.0.33",
    "@ui5/middleware-code-coverage": "^2.0.3",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "chromedriver": "^132.0.0",
    "eslint": "^9",
    "mbt": "^1.2.29",
    "rimraf": "^6.0.1",
    "tree-kill": "^1.2.2",
    "ui5-task-zipper": "^3.4.x",
    "wdio-qunit-service": "^2.0.1"
  }
}
